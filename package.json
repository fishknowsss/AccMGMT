{
  "name": "accmgmt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "local": "node scripts/open-preview.mjs",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "cf:dev": "npm run build && wrangler pages dev dist --d1 DB=accmgmt",
    "cf:migrate:local": "wrangler d1 migrations apply accmgmt --local",
    "cf:migrate": "wrangler d1 migrations apply accmgmt --remote",
    "cf:deploy": "npm run build && wrangler pages deploy dist --project-name accmgmt"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251225.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.55.0"
  }
}
